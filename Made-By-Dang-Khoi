function fn(number)
    local absNumber = math.abs(number)
    local formattedNumber
    local suffix = ""
     
    if absNumber >= 1e100 then
        formattedNumber = number / 1e100
        suffix = "G"   -- Googol (100 zeros)
    elseif absNumber >= 1e97 then
        formattedNumber = number / 1e97
        suffix = "Tg"  -- Tretrigintillion (97 zeros)
    elseif absNumber >= 1e94 then
        formattedNumber = number / 1e94
        suffix = "Dg"  -- Duotrigintillion (94 zeros)
    elseif absNumber >= 1e91 then
        formattedNumber = number / 1e91
        suffix = "Ug"  -- Untrigintillion (91 zeros)
    elseif absNumber >= 1e88 then
        formattedNumber = number / 1e88
        suffix = "Og"  -- Octovigintillion (88 zeros)
    elseif absNumber >= 1e85 then
        formattedNumber = number / 1e85
        suffix = "Sg"  -- Septenvigintillion (85 zeros)
    elseif absNumber >= 1e82 then
        formattedNumber = number / 1e82
        suffix = "sg"  -- Sexvigintillion (82 zeros)
    elseif absNumber >= 1e79 then
        formattedNumber = number / 1e79
        suffix = "Qg"  -- Quinvigintillion (79 zeros)
    elseif absNumber >= 1e76 then
        formattedNumber = number / 1e76
        suffix = "qg"  -- Quattuorvigintillion (76 zeros)
    elseif absNumber >= 1e73 then
        formattedNumber = number / 1e73
        suffix = "Tg"  -- Tresvigintillion (73 zeros)
    elseif absNumber >= 1e70 then
        formattedNumber = number / 1e70
        suffix = "Dg"  -- Duovigintillion (70 zeros)
    elseif absNumber >= 1e67 then
        formattedNumber = number / 1e67
        suffix = "Ug"  -- Unvigintillion (67 zeros)
    elseif absNumber >= 1e64 then
        formattedNumber = number / 1e64
        suffix = "V"  -- Vigintillion (64 zeros)
    elseif absNumber >= 1e61 then
        formattedNumber = number / 1e61
        suffix = "NV"  -- Novemdecillion (61 zeros)
    elseif absNumber >= 1e58 then
        formattedNumber = number / 1e58
        suffix = "OV"  -- Octodecillion (58 zeros)
    elseif absNumber >= 1e55 then
        formattedNumber = number / 1e55
        suffix = "SV"  -- Septendecillion (55 zeros)
    elseif absNumber >= 1e52 then
        formattedNumber = number / 1e52
        suffix = "sV"  -- Sexdecillion (52 zeros)
    elseif absNumber >= 1e49 then
        formattedNumber = number / 1e49
        suffix = "QV"  -- Quindecillion (49 zeros)
    elseif absNumber >= 1e46 then
        formattedNumber = number / 1e46
        suffix = "qV"  -- Quattuordecillion (46 zeros)
    elseif absNumber >= 1e43 then
        formattedNumber = number / 1e43
        suffix = "TV"  -- Tredecillion (43 zeros)
    elseif absNumber >= 1e40 then
        formattedNumber = number / 1e40
        suffix = "DV"  -- Duodecillion (40 zeros)
    elseif absNumber >= 1e37 then
        formattedNumber = number / 1e37
        suffix = "UV"  -- Undecillion (37 zeros)
    elseif absNumber >= 1e34 then
        formattedNumber = number / 1e34
        suffix = "D"  -- Decillion (34 zeros)
    elseif absNumber >= 1e31 then
        formattedNumber = number / 1e31
        suffix = "N"  -- Nonillion (31 zeros)
    elseif absNumber >= 1e28 then
        formattedNumber = number / 1e28
        suffix = "O"  -- Octillion (28 zeros)
    elseif absNumber >= 1e25 then
        formattedNumber = number / 1e25
        suffix = "S"  -- Septillion (25 zeros)
    elseif absNumber >= 1e22 then
        formattedNumber = number / 1e22
        suffix = "s"  -- Sextillion (22 zeros)
    elseif absNumber >= 1e19 then
        formattedNumber = number / 1e19
        suffix = "Q"  -- Quintillion (19 zeros)
    elseif absNumber >= 1e16 then
        formattedNumber = number / 1e16
        suffix = "q"  -- Quadrillion (16 zeros)
    elseif absNumber >= 1e13 then
        formattedNumber = number / 1e13
        suffix = "t"  -- Trillion (13 zeros)
    elseif absNumber >= 1e10 then
        formattedNumber = number / 1e10
        suffix = "B"  -- Billion (10 zeros)
    elseif absNumber >= 1e7 then
        formattedNumber = number / 1e7
        suffix = "M"  -- Million (7 zeros)
    elseif absNumber >= 1e4 then
        formattedNumber = number / 1e4
        suffix = "K"  -- Thousand (4 zeros)
    else
        formattedNumber = number
    end

    if formattedNumber % 1 ~= 0 then
        formattedNumber = string.format("%.1f", formattedNumber)
    end

    return formattedNumber .. suffix
end

